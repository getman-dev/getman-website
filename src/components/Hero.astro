---
const cdnScript = `<script src="https://cdn.getman.dev/v1/getman.min.js"></script>`;
import { githubUrl } from '../config';
import SocialProofBar from './SocialProofBar.astro';
---

<section
  class="relative px-6 pb-24 pt-20 text-center"
  style="background: linear-gradient(160deg, var(--color-gradient-warm) 0%, var(--color-bg) 60%);"
>
  <div class="mx-auto max-w-3xl">

    <!-- Badge -->
    <div class="mb-6 flex justify-center">
      <span
        class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-semibold"
        style="background-color: var(--color-badge-bg); color: var(--color-badge-text); border-color: var(--color-badge-border);"
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
        Free &amp; open source
      </span>
    </div>

    <!-- Headline -->
    <h1 class="mb-5 text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl" style="color: var(--color-text-primary);">
      The OpenAPI explorer<br />
      you'll actually{' '}
      <span
        class="relative inline-block"
        style="background: linear-gradient(transparent 55%, var(--color-highlight) 55%); border-radius: 2px;"
      >enjoy</span>{' '}
      using.
    </h1>

    <!-- Subheading -->
    <p class="mb-6 text-lg leading-relaxed sm:text-xl" style="color: var(--color-text-secondary);">
      Embeddable in any page with a single script tag.<br class="hidden sm:block" />
      No bloat, no vendor lock-in — just a clean, fast API explorer.
    </p>

    <!-- Social proof -->
    <SocialProofBar />

    <!-- CTAs -->
    <div class="mb-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="/examples"
        class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-base font-bold text-white transition-transform"
        style="background-color: var(--color-accent); box-shadow: 3px 3px 0 var(--color-accent-shadow);"
        onmouseover="this.style.transform='translate(-1px,-1px)';this.style.boxShadow='4px 4px 0 var(--color-accent-shadow)'"
        onmouseout="this.style.transform='';this.style.boxShadow='3px 3px 0 var(--color-accent-shadow)'"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
        Try a live demo
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border-2 px-6 py-3 text-base font-bold transition-transform"
        style="border-color: var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); box-shadow: 3px 3px 0 var(--color-border);"
        onmouseover="this.style.transform='translate(-1px,-1px)';this.style.boxShadow='4px 4px 0 var(--color-border)'"
        onmouseout="this.style.transform='';this.style.boxShadow='3px 3px 0 var(--color-border)'"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Install snippet -->
    <div class="mx-auto max-w-xl text-left">
      <p class="mb-1.5 text-[10px] font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">
        Quick install
      </p>
      <div
        class="flex items-center justify-between gap-3 rounded-2xl border px-4 py-3"
        style="background-color: var(--color-code-bg); border-color: var(--color-code-border);"
      >
        <code class="flex-1 truncate text-sm font-mono text-emerald-400">
          {cdnScript}
        </code>
        <button
          id="hero-copy-btn"
          data-code={cdnScript}
          class="shrink-0 rounded-lg p-1.5 transition-colors"
          style="color: #a8a29e;"
          onmouseover="this.style.color='white'"
          onmouseout="this.style.color='#a8a29e'"
          aria-label="Copy install snippet"
        >
          <svg id="hero-copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg id="hero-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden" style="color: #34d399;">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
    </div>

  </div>
</section>

<script>
  const btn = document.getElementById('hero-copy-btn');
  const copyIcon = document.getElementById('hero-copy-icon');
  const checkIcon = document.getElementById('hero-check-icon');

  btn?.addEventListener('click', async () => {
    const code = btn.dataset.code ?? '';
    await navigator.clipboard.writeText(code);
    copyIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    setTimeout(() => {
      copyIcon?.classList.remove('hidden');
      checkIcon?.classList.add('hidden');
    }, 1500);
  });
</script>