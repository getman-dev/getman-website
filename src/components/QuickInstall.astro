---
const snippet = `<!-- 1. Add a container -->
<div id="api-docs" style="height: 100vh"></div>

<!-- 2. Load the script -->
<script src="https://cdn.getman.dev/latest/getman-ui.js"><\/script>

<!-- 3. Mount -->
<script>
  GetMan.launch(
    document.getElementById('api-docs'),
    { url: 'https://your-api.com/openapi.json' }
  );
<\/script>`;
import IconCopy from './icons/IconCopy.astro';
import IconCheck from './icons/IconCheck.astro';
import IconArrowRight from './icons/IconArrowRight.astro';
---

<section
  class="px-6 py-20"
  style="background: linear-gradient(160deg, var(--color-gradient-warm) 0%, var(--color-bg) 60%);"
>
  <div class="mx-auto max-w-3xl text-center">

    <h2 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl" style="color: var(--color-text-primary);">
      One script tag. That's it.
    </h2>
    <p class="mb-10 text-base" style="color: var(--color-text-secondary);">
      No build step. No npm install. Paste these three lines and you're done.
    </p>

    <!-- Code block -->
    <div class="text-left">
      <p class="mb-2 text-[10px] font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">
        Minimal embed
      </p>
      <div
        class="relative rounded-2xl border"
        style="background-color: var(--color-code-bg); border-color: var(--color-code-border);"
      >
        <!-- Copy button -->
        <button
          id="qi-copy-btn"
          data-code={snippet}
          class="absolute right-3 top-3 flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-xs font-medium transition-colors"
          style="color: #818cf8; background: rgba(99,102,241,0.08);"
          onmouseover="this.style.background='rgba(99,102,241,0.18)';this.style.color='#c7d2fe'"
          onmouseout="this.style.background='rgba(99,102,241,0.08)';this.style.color='#818cf8'"
          aria-label="Copy code"
        >
          <IconCopy size={14} id="qi-copy-icon" />
          <IconCheck size={14} id="qi-check-icon" class="hidden" style="color: #34d399;" />
          <span id="qi-copy-label">Copy</span>
        </button>

        <!-- Code -->
        <pre class="overflow-x-auto p-5 pr-20 text-sm leading-relaxed" style="font-family: var(--font-mono);"><code id="qi-code">{snippet.split('\n').map((line, i) => {
  // colour-code the three comment lines as muted, rest as code
  if (line.startsWith('<!--')) {
    return <span style="color: #6366f1;">{line + '\n'}</span>;
  }
  if (line.includes('<script') || line.includes('<\\/script>')) {
    return <span style="color: #a5b4fc;">{line + '\n'}</span>;
  }
  if (line.includes('GetMan')) {
    return <span style="color: #c4b5fd;">{line + '\n'}</span>;
  }
  if (line.trim() === '') {
    return '\n';
  }
  return <span style="color: #e2e8f0;">{line + '\n'}</span>;
})}</code></pre>
      </div>
    </div>

    <!-- Docs link -->
    <div class="mt-6">
      <a
        href="/docs"
        class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
        style="color: var(--color-accent);"
        onmouseover="this.style.color='var(--color-accent-hover)'"
        onmouseout="this.style.color='var(--color-accent)'"
      >
        See all integration options
        <IconArrowRight size={14} />
      </a>
    </div>

  </div>
</section>

<script>
  const btn = document.getElementById('qi-copy-btn');
  const copyIcon = document.getElementById('qi-copy-icon');
  const checkIcon = document.getElementById('qi-check-icon');
  const label = document.getElementById('qi-copy-label');

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(btn.dataset.code ?? '');
    copyIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    if (label) label.textContent = 'Copied!';
    setTimeout(() => {
      copyIcon?.classList.remove('hidden');
      checkIcon?.classList.add('hidden');
      if (label) label.textContent = 'Copy';
    }, 1500);
  });
</script>