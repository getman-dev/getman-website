---
const petstoreUrl = 'https://petstore3.swagger.io/api/v3/openapi.json';
---

<section class="px-6 py-16">
  <div class="mx-auto max-w-6xl">

    <!-- Label -->
    <div class="mb-3 flex items-center gap-2">
      <span
        class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest"
        style="color: var(--color-text-muted);"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-emerald-400"></span>
        Live — fully interactive
      </span>
    </div>

    <!-- Explorer container -->
    <div
      id="inline-demo-container"
      data-spec-url={petstoreUrl}
      style="height: 600px; border-radius: 1rem; border: 1px solid var(--color-border); box-shadow: 0 4px 24px rgba(0,0,0,0.06); overflow: hidden; background: var(--color-bg);"
    >
      <!-- Skeleton shown while the script loads -->
      <div id="inline-demo-skeleton" style="height: 100%; display: flex; align-items: center; justify-content: center;">
        <div style="text-align: center; color: var(--color-text-muted);">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 8px; opacity: 0.4; animation: spin 1s linear infinite;">
            <path d="M21 12a9 9 0 1 1-6.219-8.56" />
          </svg>
          <p style="font-size: 13px;">Loading explorer…</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const container = document.getElementById('inline-demo-container') as HTMLElement | null;
  const skeleton = document.getElementById('inline-demo-skeleton');
  const specUrl = container?.dataset.specUrl ?? '';

  function mount() {
    const explorer = (window as any).ApiExplorer;
    if (explorer?.mountApiExplorer && container) {
      skeleton?.remove();
      explorer.mountApiExplorer(container, { url: specUrl });
    }
  }

  const script = document.createElement('script');
  script.src = '/getman.js';
  script.onload = mount;
  script.onerror = () => {
    if (skeleton) skeleton.innerHTML = '<p style="padding: 2rem; color: var(--color-text-muted); font-size: 13px;">Explorer failed to load.</p>';
  };
  document.head.appendChild(script);
</script>