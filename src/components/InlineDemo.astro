---
const petstoreUrl = 'https://petstore3.swagger.io/api/v3/openapi.json';
const explorerSrc = `/explorer/?spec=${encodeURIComponent(petstoreUrl)}&hideToolbar`;
---

<section class="px-6 py-16">
  <div class="mx-auto max-w-6xl">

    <!-- Label -->
    <div class="mb-3 flex items-center gap-2">
      <span
        class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest"
        style="color: var(--color-text-muted);"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-emerald-400"></span>
        Live — fully interactive
      </span>
    </div>

    <!-- Explorer iframe -->
    <iframe
      src={explorerSrc}
      title="Live API Explorer"
      class="demo-iframe"
      style="width: 100%; border-radius: 1rem; border: 1px solid var(--color-border); box-shadow: 0 4px 24px rgba(0,0,0,0.06); display: block;"
      loading="lazy"
    ></iframe>

  </div>
</section>

<style>
  .demo-iframe {
    height: 420px;
  }
  @media (min-width: 640px) {
    .demo-iframe {
      height: 600px;
    }
  }
</style>