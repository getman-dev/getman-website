---
import { githubStarsUrl } from '../config';

let stars = 0;
try {
  const res = await fetch('https://api.github.com/repos/getman-dev/getman-ui', {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const data = await res.json();
    stars = data.stargazers_count ?? 0;
  }
} catch {
  // silently fall back to no count
}

const formatted = stars > 0
  ? (stars >= 1000 ? `${(stars / 1000).toFixed(1)}k` : String(stars))
  : null;
---

<div class="mb-8 flex justify-center">
  <a
    href={githubStarsUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-semibold transition-opacity hover:opacity-80"
    style="background-color: var(--color-badge-bg); color: var(--color-badge-text); border-color: var(--color-badge-border);"
  >
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
    </svg>
    {formatted ? `${formatted} stars on GitHub` : 'Star us on GitHub'}
  </a>
</div>