---
import { githubUrl, githubStarsUrl, buyMeACoffeeUrl, xUrl } from '../config';
const currentYear = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--color-border); background-color: var(--color-bg);">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">

      <!-- Left: logo + tagline + MIT badge -->
      <div class="flex flex-col gap-4">
        <a href="/" class="flex items-center gap-3 no-underline">
          <img src="/logo.png" alt="GetMan" class="h-8 w-auto" />
          <span class="text-lg font-bold" style="color: var(--color-text-primary);">GetMan</span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          A beautiful, embeddable OpenAPI explorer.<br />Drop it anywhere with a single script tag.
        </p>
        <span
          class="inline-flex w-fit items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-semibold"
          style="background-color: var(--color-badge-bg); color: var(--color-badge-text); border-color: var(--color-badge-border);"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          MIT License — Free forever
        </span>
      </div>

      <!-- Center: nav links -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Navigation</p>
        <nav class="flex flex-col gap-2">
          {[
            { label: 'Home', href: '/' },
            { label: 'Examples', href: '/examples' },
            { label: 'Docs', href: '/docs' },
          ].map(({ label, href }) => (
            <a
              href={href}
              class="text-sm font-medium transition-colors w-fit"
              style="color: var(--color-text-secondary);"
              onmouseover="this.style.color='var(--color-text-primary)'"
              onmouseout="this.style.color='var(--color-text-secondary)'"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Right: GitHub + version -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Links</p>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm font-medium transition-colors w-fit"
          style="color: var(--color-text-secondary);"
          onmouseover="this.style.color='var(--color-text-primary)'"
          onmouseout="this.style.color='var(--color-text-secondary)'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
        <a
          href={`${githubUrl}/releases`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm w-fit"
          style="color: var(--color-text-muted);"
          onmouseover="this.style.color='var(--color-text-secondary)'"
          onmouseout="this.style.color='var(--color-text-muted)'"
        >
          <span
            class="rounded-full border px-2 py-0.5 text-xs font-mono font-medium"
            style="background-color: var(--color-badge-bg); color: var(--color-badge-text); border-color: var(--color-badge-border);"
          >
            Releases
          </span>
        </a>

        <div class="mt-4 flex flex-col gap-2 border-t pt-4" style="border-color: var(--color-border);">
          <a
            href={githubStarsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-medium transition-colors w-fit"
            style="color: var(--color-text-secondary);"
            onmouseover="this.style.color='var(--color-text-primary)'"
            onmouseout="this.style.color='var(--color-text-secondary)'"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color: var(--color-badge-text);">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            Star on GitHub
          </a>
          <a
            href={buyMeACoffeeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-medium transition-colors w-fit"
            style="color: var(--color-text-secondary);"
            onmouseover="this.style.color='var(--color-text-primary)'"
            onmouseout="this.style.color='var(--color-text-secondary)'"
          >
            ☕ Buy me a coffee
          </a>
          <a
            href={xUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-medium transition-colors w-fit"
            style="color: var(--color-text-secondary);"
            onmouseover="this.style.color='var(--color-text-primary)'"
            onmouseout="this.style.color='var(--color-text-secondary)'"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.835L2.25 2.25h6.838l4.26 5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            Follow on X
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 flex flex-col items-center justify-between gap-2 border-t pt-6 text-xs sm:flex-row"
      style="border-color: var(--color-border); color: var(--color-text-muted);"
    >
      <span>© {currentYear} GetMan — MIT License</span>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors"
        style="color: var(--color-text-muted);"
        onmouseover="this.style.color='var(--color-text-secondary)'"
        onmouseout="this.style.color='var(--color-text-muted)'"
      >
        GitHub ↗
      </a>
    </div>
  </div>
</footer>