---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FrameworkTabs from '../components/FrameworkTabs.astro';

import { githubUrl } from '../config';
import IconGitHub from '../components/icons/IconGitHub.astro';
import IconPlay from '../components/icons/IconPlay.astro';

const step1 = `<div id="api-docs" style="height: 100vh"></div>`;

const step2 = `<script src="https://cdn.getman.dev/latest/getman-ui.js"><\/script>`;

const step3 = `GetMan.launch(
  document.getElementById('api-docs'),
  { url: 'https://your-api.com/openapi.json' }
);`;
---

<BaseLayout
  title="QuickStart — GetMan Docs"
  description="Embed GetMan in any web page in 3 steps. QuickStart guide and API reference."
>
  <TopBar slot="topbar" />

  <!-- Page header -->
  <div
    class="border-b px-6 py-14 text-center"
    style="border-color: var(--color-border); background: linear-gradient(160deg, var(--color-gradient-warm) 0%, var(--color-bg) 60%);"
  >
    <h1 class="mb-3 text-4xl font-extrabold tracking-tight sm:text-5xl" style="color: var(--color-text-primary);">
      QuickStart
    </h1>
    <p class="text-lg" style="color: var(--color-text-secondary);">
      Embed GetMan in any web page in 3 steps.
    </p>
  </div>

  <!-- Docs content -->
  <div class="mx-auto max-w-3xl px-6 py-16">
    <div class="flex flex-col gap-14">

      <!-- Step 1 -->
      <section>
        <div class="mb-4 flex items-center gap-3">
          <span
            class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white"
            style="background-color: var(--color-accent);"
          >1</span>
          <h2 class="text-xl font-bold" style="color: var(--color-text-primary);">Add the container</h2>
        </div>
        <CodeBlock code={step1} label="HTML" lang="html" />
        <p class="mt-3 text-sm" style="color: var(--color-text-secondary);">
          Give the container an explicit height — GetMan fills it via <code class="rounded px-1 py-0.5 text-xs font-mono" style="background-color: var(--color-border);">height: 100%</code>.
        </p>
      </section>

      <!-- Step 2 -->
      <section>
        <div class="mb-4 flex items-center gap-3">
          <span
            class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white"
            style="background-color: var(--color-accent);"
          >2</span>
          <h2 class="text-xl font-bold" style="color: var(--color-text-primary);">Load the script</h2>
        </div>
        <CodeBlock code={step2} label="HTML" lang="html" />
        <p class="mt-3 text-sm" style="color: var(--color-text-secondary);">
          The script injects all required styles and fonts — no separate CSS import needed.
        </p>
      </section>

      <!-- Step 3 -->
      <section>
        <div class="mb-4 flex items-center gap-3">
          <span
            class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white"
            style="background-color: var(--color-accent);"
          >3</span>
          <h2 class="text-xl font-bold" style="color: var(--color-text-primary);">Mount</h2>
        </div>
        <CodeBlock code={step3} label="JavaScript" lang="js" />
        <p class="mt-3 text-sm" style="color: var(--color-text-secondary);">
          <code class="rounded px-1 py-0.5 text-xs font-mono" style="background-color: var(--color-border);">launch</code> returns
          a cleanup function — call it to unmount and release all resources.
        </p>
      </section>

      <!-- Divider -->
      <hr style="border-color: var(--color-border);" />

      <!-- Framework integration -->
      <section>
        <h2 class="mb-2 text-2xl font-bold" style="color: var(--color-text-primary);">Framework integration</h2>
        <p class="mb-6 text-sm" style="color: var(--color-text-secondary);">
          GetMan works with any framework. Pick yours below.
        </p>
        <FrameworkTabs />
      </section>

      <!-- Divider -->
      <hr style="border-color: var(--color-border);" />

      <!-- API Reference -->
      <section>
        <h2 class="mb-2 text-2xl font-bold" style="color: var(--color-text-primary);">API reference</h2>
        <p class="mb-6 text-sm font-mono" style="color: var(--color-text-secondary);">
          <code>launch(target, options?) → () =&gt; void</code>
        </p>

        <div class="overflow-x-auto rounded-2xl border" style="border-color: var(--color-border);">
          <table class="w-full text-sm">
            <thead>
              <tr style="border-bottom: 1px solid var(--color-border); background-color: var(--color-bg);">
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Parameter</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Type</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Required</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Description</th>
              </tr>
            </thead>
            <tbody>
              {[
                {
                  param: 'target',
                  type: 'HTMLElement',
                  required: true,
                  desc: 'DOM element to mount the explorer into.',
                },
                {
                  param: 'options.url',
                  type: 'string',
                  required: false,
                  desc: 'URL of the OpenAPI spec to load on startup.',
                },
              ].map((row, i) => (
                <tr style={i > 0 ? `border-top: 1px solid var(--color-border);` : ''}>
                  <td class="px-4 py-3">
                    <code class="rounded px-1.5 py-0.5 text-xs font-mono font-semibold" style="background-color: var(--color-border); color: var(--color-text-primary);">
                      {row.param}
                    </code>
                  </td>
                  <td class="px-4 py-3">
                    <code class="text-xs font-mono" style="color: var(--color-code-type);">{row.type}</code>
                  </td>
                  <td class="px-4 py-3 text-xs" style={`color: ${row.required ? '#15803d' : 'var(--color-text-muted)'};`}>
                    {row.required ? 'Yes' : 'No'}
                  </td>
                  <td class="px-4 py-3 text-sm" style="color: var(--color-text-secondary);">{row.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mt-4 text-sm" style="color: var(--color-text-secondary);">
          <strong style="color: var(--color-text-primary);">Return value:</strong>
          <code class="rounded px-1 py-0.5 text-xs font-mono" style="background-color: var(--color-border);">() =&gt; void</code>
          — call to unmount the explorer and clean up.
        </p>
      </section>

      <!-- Divider -->
      <hr style="border-color: var(--color-border);" />

      <!-- Deep linking -->
      <section>
        <h2 class="mb-2 text-2xl font-bold" style="color: var(--color-text-primary);">Deep linking</h2>
        <p class="mb-4 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          Every endpoint and schema in the explorer has a shareable URL fragment. Append these to any page
          that embeds GetMan and the explorer will scroll directly to that item on load.
        </p>
        <div class="flex flex-col gap-3">
          {[
            { fragment: '#endpoints/<operationId>', desc: 'Jump to a specific endpoint.' },
            { fragment: '#schemas/<Name>',          desc: 'Jump to a specific schema.' },
          ].map(({ fragment, desc }) => (
            <div class="flex flex-col gap-1 rounded-xl border p-4 sm:flex-row sm:items-center sm:gap-4" style="border-color: var(--color-border); background: var(--color-surface);">
              <code class="shrink-0 text-sm font-mono font-semibold" style="color: var(--color-accent);">{fragment}</code>
              <span class="text-sm" style="color: var(--color-text-secondary);">{desc}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Divider -->
      <hr style="border-color: var(--color-border);" />

      <!-- Need Help? -->
      <section>
        <h2 class="mb-4 text-2xl font-bold" style="color: var(--color-text-primary);">Need help?</h2>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={`${githubUrl}/issues`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-xl border px-5 py-3 text-sm font-semibold transition-colors"
            style="border-color: var(--color-border); color: var(--color-text-secondary); background: var(--color-surface);"
            onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-secondary)'"
          >
            <IconGitHub size={16} />
            Open a GitHub issue
          </a>
          <a
            href="/examples"
            class="flex items-center gap-2 rounded-xl border px-5 py-3 text-sm font-semibold transition-colors"
            style="border-color: var(--color-border); color: var(--color-text-secondary); background: var(--color-surface);"
            onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-secondary)'"
          >
            <IconPlay size={16} />
            See it working live
          </a>
        </div>
      </section>

    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>